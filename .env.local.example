# Copy this file to .env.local and fill in your Supabase project values.
# Both are safe to expose to the browser (NEXT_PUBLIC_ prefix) -- access is
# restricted by Row Level Security policies on the waitlist_signups table
# (see supabase/schema.sql for the exact policies).
#
# In production (Vercel), set these in Project Settings -> Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
